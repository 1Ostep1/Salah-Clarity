/* Azkar — утренние, вечерние, после намаза. Арабская транслитерация (то,
 * что читается) остаётся такой же во всех языках; переводится лишь
 * пояснение вокруг неё. */

/* Утренние азкары */
"azkar.m01.title" = "Аят аль-Курси";
"azkar.m01.body"  = "Прочитайте Аят аль-Курси (2:255) один раз. Кто прочтёт его утром — будет защищён до вечера.";

"azkar.m02.title" = "Сура аль-Ихлас (×3)";
"azkar.m02.body"  = "Куль хуваллаху ахад… Читайте суры аль-Ихлас, аль-Фаляк и ан-Нас по три раза каждую.";

"azkar.m03.title" = "Утреннее поминание";
"azkar.m03.body"  = "Асбахна ва асбахаль-мульку лилляхи, валь-хамду лилляхи… (Мы встретили утро, и царство принадлежит Аллаху.)";

"azkar.m04.title" = "Саййид аль-Истигфар";
"azkar.m04.body"  = "Аллахумма анта Рабби, ля иляха илля анта, халяктани ва ана абдук… Кто скажет это с убеждённостью утром и умрёт в тот же день — будет из обитателей Рая.";

"azkar.m05.title" = "СубханАллахи ва бихамдих (×100)";
"azkar.m05.body"  = "Субхан-Аллахи ва бихамдих — сто раз. Никто не придёт с чем-то лучшим, кроме того, кто сказал так же или больше.";

"azkar.m06.title" = "Ля иляха илля Аллах (×10)";
"azkar.m06.body"  = "Ля иляха илля Аллаху вахдаху ля шарика лях, ляхуль-мульку ва ляхуль-хамду ва хува аля кулли шай'ин кадир — десять раз.";

"azkar.m07.title" = "Защита от всякого зла";
"azkar.m07.body"  = "Бисмилляхил-лязи ля йадурру ма'а исмихи шай'ун фил-арди ва ля фис-самаи ва хувас-Сами'уль-'Алим — три раза.";

"azkar.m08.title" = "Довольство Исламом";
"azkar.m08.body"  = "Радиту билляхи Раббан, ва биль-Ислами динан, ва би-Мухаммадин, саллалаху алайхи ва салляма, набиййан — три раза.";

"azkar.m09.title" = "Хасби Аллах (×7)";
"azkar.m09.body"  = "Хасбийаллаху ля иляха илля хува, 'алейхи таваккяльту ва хува Раббуль-'Аршиль-'Азим — семь раз.";

"azkar.m10.title" = "Аллахумма 'афини фи бадани";
"azkar.m10.body"  = "О Аллах, даруй здоровье моему телу, слуху и зрению — три раза.";

"azkar.m11.title" = "Асбахна 'аля фитратиль-Ислам";
"azkar.m11.body"  = "Мы встретили утро в истинной природе Ислама, на слове искренности, на религии нашего Пророка ﷺ и вере нашего отца Ибрахима.";

"azkar.m12.title" = "Аллахумма бика асбахна";
"azkar.m12.body"  = "О Аллах, с Тобой мы встретили утро и с Тобой — вечер; с Тобой живём и умираем, и к Тебе воскресение.";

"azkar.m13.title" = "Прибегание к словам Аллаха (×3)";
"azkar.m13.body"  = "А'узу би-калимятилляхит-таммати мин шарри ма халяк — три раза. Кто скажет это утром — ничто не причинит ему вреда в тот день.";

"azkar.m14.title" = "Дуа о руководстве";
"azkar.m14.body"  = "Аллахумма инни ас'алюка 'ильман нафи'ан, ва ризкан таййибан, ва 'амалян мутакаббаля.";

"azkar.m15.title" = "Прошу Рая, убежища от Огня";
"azkar.m15.body"  = "Аллахумма инни ас'алюкаль-джанната, ва а'узу бика минан-нар — три раза.";

"azkar.m16.title" = "Йа Хаййу йа Каййум";
"azkar.m16.body"  = "Йа Хаййу йа Каййум, би-рахматика астагис, аслих ли ша'ни куллаху, ва ля такильни иля нафси тарфата 'айн.";

"azkar.m17.title" = "Альхамдулиллях — за полноценное утро";
"azkar.m17.body"  = "Альхамдулилляхиль-лязи 'афани фи джасади, ва радда 'алеййа рухи, ва азина ли би-зикрих.";

"azkar.m18.title" = "Истигфар × 100";
"azkar.m18.body"  = "Астагфируллах — просите прощения сто раз. Пророк ﷺ делал это ежедневно.";

"azkar.m19.title" = "Благословения Пророку ﷺ (×10)";
"azkar.m19.body"  = "Аллахумма салли ва саллим 'аля набиййина Мухаммад — десять раз. Кто сделает так — моё заступничество ему обязательно.";

/* Вечерние азкары */
"azkar.e01.title" = "Аят аль-Курси";
"azkar.e01.body"  = "Прочитайте Аят аль-Курси (2:255) один раз вечером — для защиты в течение ночи.";

"azkar.e02.title" = "Аль-Ихлас, аль-Фаляк, ан-Нас (×3)";
"azkar.e02.body"  = "Трёхкратное чтение каждой из последних трёх сур вечером защитит вас.";

"azkar.e03.title" = "Амсайна ва амсаль-мульку лилляхи";
"azkar.e03.body"  = "Мы встретили вечер, и всё царство принадлежит Аллаху; вся хвала — Аллаху.";

"azkar.e04.title" = "Саййид аль-Истигфар";
"azkar.e04.body"  = "Аллахумма анта Рабби… Кто скажет это с убеждённостью вечером и умрёт до утра — будет из обитателей Рая.";

"azkar.e05.title" = "А'узу би-калимятиллях (×3)";
"azkar.e05.body"  = "А'узу би-калимятилляхит-таммати мин шарри ма халяк — три раза вечером защищают от укусов скорпиона в ту ночь.";

"azkar.e06.title" = "Ля иляха илля Аллах (×10 или ×100)";
"azkar.e06.body"  = "Ля иляха илля Аллаху вахдаху ля шарика лях… Кто скажет это сто раз в день — как если бы освободил десять рабов.";

"azkar.e07.title" = "СубханАллахи ва бихамдих (×100)";
"azkar.e07.body"  = "Стирает грехи, даже если они подобны морской пене.";

"azkar.e08.title" = "Защита с именем Аллаха (×3)";
"azkar.e08.body"  = "Бисмилляхил-лязи ля йадурру ма'а исмихи шай'ун фил-арди ва ля фис-самаи ва хувас-Сами'уль-'Алим.";

"azkar.e09.title" = "Прибегание от лени, старости, долга";
"azkar.e09.body"  = "Аллахумма инни а'узу бика миналь-касаль, валь-харами, валь-ма'сами, валь-маграм.";

"azkar.e10.title" = "Йа мукаллибаль-кулюб";
"azkar.e10.body"  = "О Тот, Кто изменяет сердца, укрепи моё сердце на Твоей религии.";

"azkar.e11.title" = "Хасби Аллах (×7)";
"azkar.e11.body"  = "Хасбийаллаху ля иляха илля хува, 'алейхи таваккяльту ва хува Раббуль-'Аршиль-'Азим — семь раз.";

"azkar.e12.title" = "Дуа перед сном";
"azkar.e12.body"  = "Бисмика Аллахумма амуту ва ахья. С Твоим именем, о Аллах, я умираю и живу.";

"azkar.e13.title" = "Последние два аята аль-Бакара";
"azkar.e13.body"  = "Кто прочтёт последние два аята суры аль-Бакара ночью — их будет ему достаточно.";

"azkar.e14.title" = "Истигфар × 100";
"azkar.e14.body"  = "Просите прощения сто раз — ежедневная привычка Пророка ﷺ.";

"azkar.e15.title" = "Радиту билляхи Раббан";
"azkar.e15.body"  = "Я доволен Аллахом как Господом, Исламом как религией и Мухаммадом ﷺ как Пророком — три раза.";

"azkar.e16.title" = "Салават Пророку ﷺ (×10)";
"azkar.e16.body"  = "Десять салаватов Посланнику ﷺ вечером — моё заступничество становится обязательным.";

"azkar.e17.title" = "Сура аль-Мульк";
"azkar.e17.body"  = "Читайте суру аль-Мульк ночью — она заступится за читающего до его прощения.";

"azkar.e18.title" = "Дуа о благе семьи";
"azkar.e18.body"  = "Аллахумма ахсин акибатана филь-умури куллиха, ва аджирна мин хизйид-дунья ва 'азабиль-ахира.";

"azkar.e19.title" = "Твёрдость в Исламе до утра";
"azkar.e19.body"  = "Амсайна 'аля фитратиль-Ислам, ва калиматиль-ихляс, ва 'аля дини набиййина Мухаммад ﷺ…";

"azkar.e20.title" = "Умиротворённое сердце";
"azkar.e20.body"  = "Аллахумма инни ас'алюка нафсан бика мутма'иннах, ту'мину билика'ик, ва тарда би када'ик.";

/* Азкары после намаза */
"azkar.p01.title" = "Астагфируллах (×3)";
"azkar.p01.body"  = "Попросите прощения три раза, затем: Аллахумма анта ас-Салям ва минка ас-Салям, табаракта йа зуль-джаляли валь-икрам.";

"azkar.p02.title" = "Ля иляха илля Аллах";
"azkar.p02.body"  = "Ля иляха илля Аллаху вахдаху ля шарика лях, ляхуль-мульку ва ляхуль-хамду, ва хува 'аля кулли шай'ин кадир.";

"azkar.p03.title" = "Аллахумма ля мани'а";
"azkar.p03.body"  = "Аллахумма ля мани'а лима а'тайт, ва ля му'тыя лима мана'т, ва ля йанфа'у заль-джадди минка аль-джадд.";

"azkar.p04.title" = "Тасбих — 33/33/34";
"azkar.p04.body"  = "Субхан-Аллах (×33), Альхамду лиллях (×33), Аллаху Акбар (×33), затем один раз: Ля иляха илля Аллах… Его грехи будут прощены, даже если они подобны морской пене.";

"azkar.p05.title" = "Аят аль-Курси";
"azkar.p05.body"  = "Кто прочтёт Аят аль-Курси после каждой обязательной молитвы — между ним и Раем нет ничего, кроме смерти.";

"azkar.p06.title" = "Три «Куль» (после Фаджра и Магриба)";
"azkar.p06.body"  = "Прочитайте суры аль-Ихлас, аль-Фаляк и ан-Нас по три раза после Фаджра и Магриба.";

"azkar.p07.title" = "Помоги мне поминать Тебя";
"azkar.p07.body"  = "Аллахумма а'инни 'аля зикрика, ва шукрика, ва хусни 'ибадатик.";

"azkar.p08.title" = "Прибегание от четырёх";
"azkar.p08.body"  = "Аллахумма инни а'узу бика мин 'азаби джаханнам, ва мин 'азабиль-кабр, ва мин фитнатиль-махья валь-мамат, ва мин фитнатиль-масих ад-Даджаль.";

"azkar.p09.title" = "Десять произнесений (после Фаджра и Магриба)";
"azkar.p09.body"  = "Ля иляха илля Аллах… ва хува 'аля кулли шай'ин кадир — десять раз после Фаджра и Магриба.";

"azkar.p10.title" = "Дуа о полезном знании (после Фаджра)";
"azkar.p10.body"  = "Аллахумма инни ас'алюка 'ильман нафи'ан, ва ризкан таййибан, ва 'амалян мутакаббаля.";

"azkar.p11.title" = "Салават Пророку ﷺ";
"azkar.p11.body"  = "Отправьте салават Посланнику ﷺ десять раз после каждой обязательной молитвы.";

"azkar.p12.title" = "Дуа о руководстве";
"azkar.p12.body"  = "Аллахумма инни ас'алюкаль-худа ват-тука валь-'афафа валь-гина.";

"azkar.p13.title" = "Прибегание от слабости";
"azkar.p13.body"  = "Аллахумма инни а'узу бика миналь-'аджзи валь-касаль, валь-джубни валь-бухль, ва дала'ид-дайни ва галябатир-риджаль.";

"azkar.p14.title" = "Укрепи сердце";
"azkar.p14.body"  = "Йа мукаллибаль-кулюб, саббит кальби 'аля диник.";

"azkar.p15.title" = "Дуа о прощении родителей";
"azkar.p15.body"  = "Рабби-гфир ли ва ли валидаййа ва лиль-му'минина йаума йакумуль-хисаб.";

/* Hadiths — 100 */

"hadith.h01.title" = "Намерение";
"hadith.h01.body"  = "Дела — только по намерениям, и каждому достанется только то, что он намеревался.";

"hadith.h02.title" = "Лучшие из вас";
"hadith.h02.body"  = "Лучшие из вас — те, у кого лучший нрав и поведение.";

"hadith.h03.title" = "Любовь к брату";
"hadith.h03.body"  = "Никто из вас не уверует по-настоящему, пока не будет желать своему брату того же, что желает себе.";

"hadith.h04.title" = "Улыбка — милостыня";
"hadith.h04.body"  = "Твоя улыбка брату — это милостыня (садака).";

"hadith.h05.title" = "Пять столпов";
"hadith.h05.body"  = "Ислам построен на пяти: свидетельство, что нет божества, кроме Аллаха, и что Мухаммад — Его Посланник; молитва, закят, паломничество и пост Рамадана.";

"hadith.h06.title" = "Аллах прекрасен";
"hadith.h06.body"  = "Воистину, Аллах прекрасен и любит красоту.";

"hadith.h07.title" = "Молитва вовремя";
"hadith.h07.body"  = "Самое любимое дело пред Аллахом — молитва, совершённая в своё время.";

"hadith.h08.title" = "Милосердие";
"hadith.h08.body"  = "К милосердным проявит милосердие Милостивый. Будьте милосердны к тем, кто на земле — и Тот, Кто над небесами, окажет милость вам.";

"hadith.h09.title" = "Доброе слово";
"hadith.h09.body"  = "Кто верует в Аллаха и в Последний день, пусть говорит доброе или молчит.";

"hadith.h10.title" = "Приветливость";
"hadith.h10.body"  = "Не пренебрегайте ни одним добрым делом — даже встречей брата с приветливым лицом.";

"hadith.h11.title" = "Два блага";
"hadith.h11.body"  = "Два блага многие упускают: здоровье и свободное время.";

"hadith.h12.title" = "Постоянство";
"hadith.h12.body"  = "Самые любимые дела пред Аллахом — те, что совершаются постоянно, пусть даже немного.";

"hadith.h13.title" = "Семь под сенью";
"hadith.h13.body"  = "Семеро окажутся под сенью Аллаха в День, когда не будет иной тени, кроме Его — среди них юноша, выросший в поклонении Аллаху.";

"hadith.h14.title" = "Положение верующего";
"hadith.h14.body"  = "Удивительно положение верующего — всё для него благо, и так только у верующего.";

"hadith.h15.title" = "Щедрый Господь";
"hadith.h15.body"  = "Ваш Господь стыдлив и щедр; когда раб поднимает к Нему руки, Он стесняется вернуть их пустыми.";

"hadith.h16.title" = "Покаяние";
"hadith.h16.body"  = "Все потомки Адама — грешники, а лучшие из грешников — те, кто кается.";

"hadith.h17.title" = "Искание знаний";
"hadith.h17.body"  = "Кто пройдёт путь в поисках знания — Аллах облегчит ему путь в Рай.";

"hadith.h18.title" = "Залог Рая";
"hadith.h18.body"  = "Кто убережёт для меня то, что между челюстями, и то, что между ног, — тому я ручаюсь за Рай.";

"hadith.h19.title" = "Смотрите на нижестоящих";
"hadith.h19.body"  = "В мирском смотрите на тех, кто ниже вас, а в делах религии — на тех, кто выше: это ближе к тому, чтобы вы не забывали о милости Аллаха.";

"hadith.h20.title" = "Сосед";
"hadith.h20.body"  = "Джибриль столько наставлял меня о соседе, что я думал — он сделает его наследником.";

"hadith.h21.title" = "Скромность";
"hadith.h21.body"  = "Скромность (хайа) не приносит ничего, кроме блага.";

"hadith.h22.title" = "Удержи язык";
"hadith.h22.body"  = "Сообщить ли тебе об основе всего этого? Удержи вот это — и он указал на свой язык.";

"hadith.h23.title" = "Добро стирает зло";
"hadith.h23.body"  = "Вслед за плохим делом делай доброе — оно сотрёт плохое. И относись к людям по-доброму.";

"hadith.h24.title" = "Самые близкие в Судный день";
"hadith.h24.body"  = "Самые любимые мне и самые близкие ко мне в Судный день — те, у кого лучший нрав.";

"hadith.h25.title" = "Милостыня не убавит";
"hadith.h25.body"  = "Милостыня не уменьшает богатства; кто прощает, того Аллах возвышает в чести.";

"hadith.h26.title" = "Настоящий сильный";
"hadith.h26.body"  = "Сильный — не тот, кто побеждает в борьбе, а тот, кто владеет собой в гневе.";

"hadith.h27.title" = "Две прохладные молитвы";
"hadith.h27.body"  = "Кто совершит две прохладные молитвы — фаджр и аср — войдёт в Рай.";

"hadith.h28.title" = "Мусульманин";
"hadith.h28.body"  = "Мусульманин — тот, от языка и руки которого в безопасности другие мусульмане.";

"hadith.h29.title" = "Облегчи брату";
"hadith.h29.body"  = "Кто облегчит верующему горе этого мира, тому Аллах облегчит горе в Судный день.";

"hadith.h30.title" = "Любовь к Пророку ﷺ";
"hadith.h30.body"  = "Никто из вас не уверует, пока я не стану для него дороже его отца, его ребёнка и всех людей.";

"hadith.h31.title" = "Чистота — половина веры";
"hadith.h31.body"  = "Чистота — половина веры, а «Альхамду лиллях» наполняет весы.";

"hadith.h32.title" = "Дуа — это поклонение";
"hadith.h32.body"  = "Дуа — это и есть суть поклонения.";

"hadith.h33.title" = "Искреннее прошение шахады";
"hadith.h33.body"  = "Кто искренне просит Аллаха о мученичестве — Аллах дарует ему степень шахида, даже если тот умрёт в своей постели.";

"hadith.h34.title" = "Аллах радуется покаянию";
"hadith.h34.body"  = "Аллах радуется покаянию Своего раба больше, чем кто-то из вас радуется, найдя в пустыне свою потерянную верблюдицу.";

"hadith.h35.title" = "Берегитесь сплетен";
"hadith.h35.body"  = "Знаете ли вы, что такое гийба? Упомянуть брата тем, что ему неприятно. Если это в нём — ты оклеветал его; если нет — ты солгал о нём.";

"hadith.h36.title" = "Поднятие рук в дуа";
"hadith.h36.body"  = "Ваш Господь не разочаровывает раба, поднимающего к Нему руки в дуа, возвращая их пустыми.";

"hadith.h37.title" = "Обязанность";
"hadith.h37.body"  = "Искание знаний — обязанность каждого мусульманина.";

"hadith.h38.title" = "Дела — по концовке";
"hadith.h38.body"  = "Дела оцениваются по их концам.";

"hadith.h39.title" = "Два лёгких слова";
"hadith.h39.body"  = "Два слова лёгкие на языке, тяжёлые на весах и любимые Милостивым: «СубханАллахи ва бихамдих, СубханАллахиль-Азым».";

"hadith.h40.title" = "Тасбих наполняет чашу";
"hadith.h40.body"  = "Кто скажет «СубханАллахи ва бихамдих» сто раз в день — его грехи будут прощены, даже если они подобны морской пене.";

"hadith.h41.title" = "С именем Аллаха";
"hadith.h41.body"  = "Всякое важное дело, не начатое с имени Аллаха, лишено благословения.";

"hadith.h42.title" = "Оставь сомнительное";
"hadith.h42.body"  = "Оставь то, что вызывает у тебя сомнение, ради того, что сомнения не вызывает.";

"hadith.h43.title" = "Бедные войдут раньше";
"hadith.h43.body"  = "Бедные верующие войдут в Рай на пятьсот лет раньше богатых.";

"hadith.h44.title" = "Терпение — свет";
"hadith.h44.body"  = "Терпение — свет. Молитва — свет. Коран — довод за тебя или против тебя.";

"hadith.h45.title" = "Зависть сжигает";
"hadith.h45.body"  = "Остерегайтесь зависти, ибо она поедает добрые дела, как огонь — дрова.";

"hadith.h46.title" = "Помоги брату";
"hadith.h46.body"  = "Кто избавит мусульманина от мирской трудности, того Аллах избавит от трудности Судного дня.";

"hadith.h47.title" = "Верхняя рука";
"hadith.h47.body"  = "Верхняя рука лучше нижней: дающий лучше берущего.";

"hadith.h48.title" = "Забота о других";
"hadith.h48.body"  = "Никто из вас не уверует по-настоящему, пока не будет желать брату того же, что желает себе.";

"hadith.h49.title" = "Три, что остаются";
"hadith.h49.body"  = "Когда человек умирает, дела его прекращаются, кроме трёх: текущая милостыня, знание, которое приносит пользу, и праведный потомок, который делает за него дуа.";

"hadith.h50.title" = "Лучшая милостыня в Рамадан";
"hadith.h50.body"  = "Лучшая милостыня — та, что даётся в Рамадан.";

"hadith.h51.title" = "Ночь аль-Кадр";
"hadith.h51.body"  = "Кто простоит в молитве ночь аль-Кадр с верой и надеждой на награду — ему простятся прошлые грехи.";

"hadith.h52.title" = "Самый полезный";
"hadith.h52.body"  = "Лучшие из людей — те, кто наиболее полезны людям.";

"hadith.h53.title" = "Аллах любит мягкость";
"hadith.h53.body"  = "Аллах — Кроткий, Он любит мягкость и даёт через мягкость то, что не даёт через резкость.";

"hadith.h54.title" = "Почитай соседа";
"hadith.h54.body"  = "Кто верует в Аллаха и в Последний день — пусть почитает своего соседа.";

"hadith.h55.title" = "Оставь ложь";
"hadith.h55.body"  = "Я ручаюсь за дом на окраинах Рая тому, кто оставит ложь — даже в шутку.";

"hadith.h56.title" = "Доброе слово";
"hadith.h56.body"  = "Доброе слово — это милостыня.";

"hadith.h57.title" = "Убери вред с дороги";
"hadith.h57.body"  = "У веры более семидесяти ветвей — высшая из них — свидетельство веры, а низшая — убрать вредное с дороги.";

"hadith.h58.title" = "Правдивость";
"hadith.h58.body"  = "Правдивость ведёт к праведности, а праведность — в Рай.";

"hadith.h59.title" = "Последние аяты аль-Кахфа";
"hadith.h59.body"  = "Кто выучит наизусть последние десять аятов суры аль-Кахф, будет защищён от Даджаля.";

"hadith.h60.title" = "Мягкость украшает";
"hadith.h60.body"  = "Мягкость украшает всё, где она есть, и лишает красоты то, у чего её отнимут.";

"hadith.h61.title" = "Верующие — одно тело";
"hadith.h61.body"  = "Верующие во взаимной любви — как одно тело: когда болит один орган, всё тело отвечает жаром и бессонницей.";

"hadith.h62.title" = "Путь правдивости";
"hadith.h62.body"  = "Человек говорит правду, пока у Аллаха он не будет записан правдивым.";

"hadith.h63.title" = "Тайная милостыня";
"hadith.h63.body"  = "Среди семерых под сенью Аллаха — тот, кто дал милостыню так скрытно, что левая рука не знала, что подала правая.";

"hadith.h64.title" = "Разговейтесь финиками";
"hadith.h64.body"  = "Когда один из вас прерывает пост, пусть прервёт финиками; если не найдёт — то водой, ибо она очищает.";

"hadith.h65.title" = "Пост и Коран — заступники";
"hadith.h65.body"  = "Пост и Коран будут ходатайствовать за раба в Судный день.";

"hadith.h66.title" = "Пост с верой";
"hadith.h66.body"  = "Кто соблюдает пост Рамадана с верой и надеждой на награду — тому простятся прошлые грехи.";

"hadith.h67.title" = "Три дуа, не отвергаемые";
"hadith.h67.body"  = "Три дуа не отвергаются: дуа постящегося, притеснённого и путника.";

"hadith.h68.title" = "Кусочек плоти";
"hadith.h68.body"  = "В теле есть кусочек плоти: если он благ, благо и всё тело; если испорчен — испорчено и всё тело. Это сердце.";

"hadith.h69.title" = "Он смотрит на сердца";
"hadith.h69.body"  = "Аллах не смотрит на ваш облик и богатство — Он смотрит на ваши сердца и дела.";

"hadith.h70.title" = "Фаджр под защитой";
"hadith.h70.body"  = "Кто совершит фаджр — тот под защитой Аллаха.";

"hadith.h71.title" = "Темница для верующего";
"hadith.h71.body"  = "Этот мир — темница для верующего и рай для неверующего.";

"hadith.h72.title" = "Достаточно греха";
"hadith.h72.body"  = "Достаточно греха человеку — пренебречь теми, кто на его попечении.";

"hadith.h73.title" = "Семь губящих";
"hadith.h73.body"  = "Избегайте семи губящих: ширк, колдовство, убийство без права, ростовщичество, поедание имущества сироты, бегство с поля боя, клевета на целомудренных.";

"hadith.h74.title" = "Праведность — благонравие";
"hadith.h74.body"  = "Праведность — благой нрав; грех — то, что колеблется в сердце и чего ты не хочешь, чтобы узнали люди.";

"hadith.h75.title" = "Лучшие товарищи";
"hadith.h75.body"  = "Лучшие товарищи пред Аллахом — те, кто более полезен своим товарищам; лучшие соседи — те, кто более полезен своим соседям.";

"hadith.h76.title" = "Двенадцать ракатов";
"hadith.h76.body"  = "Кто совершит двенадцать добровольных ракатов в сутки — для него будет построен дом в Раю.";

"hadith.h77.title" = "Аллах нисходит ночью";
"hadith.h77.body"  = "В последнюю треть ночи наш Господь нисходит и говорит: «Кто взывает ко Мне — Я отвечу ему; кто просит у Меня — Я дам ему; кто ищет Моего прощения — Я прощу его».";

"hadith.h78.title" = "Гусль в пятницу";
"hadith.h78.body"  = "Гусль в день джум'а — обязанность каждого совершеннолетнего.";

"hadith.h79.title" = "Садака каждого сустава";
"hadith.h79.body"  = "Каждое утро каждому суставу человека надлежит милостыня — и два раката духа заменяют всё это.";

"hadith.h80.title" = "Религия — искренность";
"hadith.h80.body"  = "Религия — это искренность: пред Аллахом, Его Книгой, Его Посланником, и пред правителями и простыми мусульманами.";

"hadith.h81.title" = "Относись к людям хорошо";
"hadith.h81.body"  = "Бойся Аллаха, где бы ты ни был; за плохим делом следуй добрым — оно сотрёт его; и обращайся с людьми по-доброму.";

"hadith.h82.title" = "Гнев от шайтана";
"hadith.h82.body"  = "Гнев — от шайтана. Если кто-то разгневался стоя — пусть сядет; если пройдёт — хорошо, иначе пусть ляжет.";

"hadith.h83.title" = "Даже полфиника";
"hadith.h83.body"  = "Защити себя от Огня — даже половинкой финика; а если не найдёшь — добрым словом.";

"hadith.h84.title" = "Читайте пока согласны";
"hadith.h84.body"  = "Читайте Коран, пока ваши сердца согласны; когда расходитесь — встаньте и оставьте.";

"hadith.h85.title" = "Проси прощения и кайся";
"hadith.h85.body"  = "Клянусь Аллахом, я прошу у Него прощения и каюсь более семидесяти раз в день.";

"hadith.h86.title" = "Ля иляха илля Аллах × 100";
"hadith.h86.body"  = "Кто сто раз в день скажет «Ля иляха илля Аллах» — это равно освобождению десяти рабов, и ему записывают сто добрых дел.";

"hadith.h87.title" = "Заступничество в Судный день";
"hadith.h87.body"  = "У каждого Пророка есть принимаемая дуа. Я сохранил свою как заступничество за мою умму в Судный день.";

"hadith.h88.title" = "Испытания стирают грехи";
"hadith.h88.body"  = "Не постигает мусульманина усталость, болезнь, печаль или вред — даже укол шипа — чтобы Аллах не стёр этим часть его грехов.";

"hadith.h89.title" = "Постоянство в сунне";
"hadith.h89.body"  = "Кто постоянно совершает двенадцать сунна-ракатов в сутки — для него строится дом в Раю.";

"hadith.h90.title" = "Лучшее дуа";
"hadith.h90.body"  = "Лучшее дуа: «Господь наш, даруй нам благо в этом мире и благо в будущем, и защити нас от мучений Огня».";

"hadith.h91.title" = "Его нрав — Коран";
"hadith.h91.body"  = "Нрав Посланника Аллаха ﷺ был Кораном.";

"hadith.h92.title" = "Закят очищает имущество";
"hadith.h92.body"  = "Закят — мост Ислама: он очищает имущество и угоден Милостивому.";

"hadith.h93.title" = "Никому не отказывал";
"hadith.h93.body"  = "Посланник Аллаха ﷺ никогда не отказывал в просьбе, на которую у него было чем ответить.";

"hadith.h94.title" = "Помните о смерти";
"hadith.h94.body"  = "Часто поминайте разрушителя наслаждений — смерть.";

"hadith.h95.title" = "Щедрый близок";
"hadith.h95.body"  = "Щедрый близок к Аллаху, близок к людям, близок к Раю и далёк от Огня.";

"hadith.h96.title" = "Почитание матери";
"hadith.h96.body"  = "«О Посланник Аллаха, кто больше всех достоин моего добра?» Он сказал: «Твоя мать». — «А потом?» — «Твоя мать». — «А потом?» — «Твоя мать». — «А потом?» — «Твой отец».";

"hadith.h97.title" = "Пылинка высокомерия";
"hadith.h97.body"  = "Не войдёт в Рай тот, в сердце которого есть высокомерие весом с горчичное зёрнышко.";

"hadith.h98.title" = "Лучший для семьи";
"hadith.h98.body"  = "Лучший из вас — тот, кто лучший для своей семьи. А я — лучший из вас для своей семьи.";

"hadith.h99.title" = "Мусульманин неприкосновенен";
"hadith.h99.body"  = "Каждый мусульманин неприкосновенен для другого мусульманина: его кровь, его имущество и его честь.";

"hadith.h100.title" = "Храни Аллаха";
"hadith.h100.body"  = "Храни Аллаха — и Он сохранит тебя. Храни Аллаха — и ты найдёшь Его перед собой. Когда просишь — проси у Аллаха; когда ищешь помощи — ищи у Аллаха.";
