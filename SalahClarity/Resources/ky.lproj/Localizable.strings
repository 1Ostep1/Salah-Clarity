/* Азкарлар — эртеңки, кечки, намаздан кийинкилер. Арабча транслитерация
 * (айтыла турган сөздөр) баардык тилдерде бирдей калат — тегерегиндеги
 * түшүндүрмө гана которулат. */

/* Эртеңки азкарлар */
"azkar.m01.title" = "Аят аль-Курси";
"azkar.m01.body"  = "Аят аль-Курсини (2:255) бир жолу окуңуз. Ким аны эртең менен окуса — кечке чейин корголот.";

"azkar.m02.title" = "Аль-Ихлас сүрөөсү (×3)";
"azkar.m02.body"  = "Куль хувваллаху ахад… Аль-Ихлас, аль-Фалак жана ан-Нас сүрөөлөрүн үч жолу окуңуз.";

"azkar.m03.title" = "Эртеңки зикир";
"azkar.m03.body"  = "Асбахна ва асбахаль-мульку лилляхи, валь-хамду лилляхи… (Биз эртең менен жетипиз, мүлк Аллахка таандык.)";

"azkar.m04.title" = "Сеййид аль-Истигфар";
"azkar.m04.body"  = "Аллахумма анта Рабби, ля иляха илля анта, халяктани ва ана абдук… Ким муну ишенч менен эртең айтып, ошол күнү каза болсо — Бейиштин ээлеринен болот.";

"azkar.m05.title" = "СубханАллахи ва бихамдих (×100)";
"azkar.m05.body"  = "Субхан-Аллахи ва бихамдих — жүз жолу. Муну же ашыгын айткандан башка эч ким мындан жакшы нерсе менен келбейт.";

"azkar.m06.title" = "Ля иляха илля Аллах (×10)";
"azkar.m06.body"  = "Ля иляха илля Аллаху уахдаху ля шарика лях, ляхуль-мульку ва ляхуль-хамду ва хуа аля кулли шей'ин кадир — он жолу.";

"azkar.m07.title" = "Ар кандай жамандыктан коргонуу";
"azkar.m07.body"  = "Бисмилляхил-лязи ля йадурру ма'а исмихи шей'ун фил-арди ва ля фис-сама'и ва хувас-Сами'уль-'Алим — үч жолу.";

"azkar.m08.title" = "Исламга ыраазычылык";
"azkar.m08.body"  = "Радиту билляхи Раббан, ва биль-Ислями динан, ва би-Мухаммадин, саллалаху алейхи ва саллям, набиййан — үч жолу.";

"azkar.m09.title" = "Хасби Аллах (×7)";
"azkar.m09.body"  = "Хасбийаллаху ля иляха илля хуа, 'алейхи таваккяльту ва хуа Раббуль-'Аршиль-'Азим — жети жолу.";

"azkar.m10.title" = "Аллахумма 'афини фи бадани";
"azkar.m10.body"  = "Оо Аллах, денемди, угуумду жана көзүмдү аман-эсен кыл — үч жолу.";

"azkar.m11.title" = "Асбахна 'аля фитратиль-Ислам";
"azkar.m11.body"  = "Биз Ислам табиятына, ихлас сөзүнө, Пайгамбарыбыз Мухаммаддын ﷺ динине жана атабыз Ибрахимдин ыйманына бекем эртенди тосуп алдык.";

"azkar.m12.title" = "Аллахумма бика асбахна";
"azkar.m12.body"  = "Оо Аллах, Сенин күчүң менен эрте жеттик, Сенин күчүң менен кеч жетебиз; Сенден жашап өлөбүз, жана Сага кайтабыз.";

"azkar.m13.title" = "Аллахтын сөздөрүнө баш калкалоо (×3)";
"azkar.m13.body"  = "А'узу би-калимятилляхит-таммати мин шарри ма халяк — үч жолу. Ким аны эртең менен айтса — ошол күнү ага зыян тийбейт.";

"azkar.m14.title" = "Жол көрсөтүү үчүн дуба";
"azkar.m14.body"  = "Аллахумма инни ас'алюка 'ильман нафи'ан, ва ризкан таййибан, ва 'амалян мутакаббаля.";

"azkar.m15.title" = "Бейишти тилеп, Оттон калкалоо";
"azkar.m15.body"  = "Аллахумма инни ас'алюкаль-джаннах, ва а'узу бика минан-нар — үч жолу.";

"azkar.m16.title" = "Йа Хайю йа Каййум";
"azkar.m16.body"  = "Йа Хайю йа Каййум, би-рахматика астагис, аслих ли ша'ни куллаху, ва ля такильни иля нафси тарфата 'айн.";

"azkar.m17.title" = "Альхамдулиллах — толук эртең үчүн";
"azkar.m17.body"  = "Альхамдулилляхиль-лязи 'афани фи джасади, ва радда 'алейа рухи, ва азина ли би-зикрих.";

"azkar.m18.title" = "Истигфар × 100";
"azkar.m18.body"  = "Астагфируллах — жүз жолу кечирим сураңыз. Пайгамбар ﷺ муну күнүгө жасачу.";

"azkar.m19.title" = "Пайгамбарга ﷺ салауат (×10)";
"azkar.m19.body"  = "Аллахумма салли ва саллим 'аля набиййина Мухаммад — он жолу. Ким муну жасаса — мен ага шапаатчы болом.";

/* Кечки азкарлар */
"azkar.e01.title" = "Аят аль-Курси";
"azkar.e01.body"  = "Аят аль-Курсини (2:255) кеч бир жолу окуңуз — түнү бою корголуу үчүн.";

"azkar.e02.title" = "Аль-Ихлас, аль-Фалак, ан-Нас (×3)";
"azkar.e02.body"  = "Кечинде акыркы үч сүрөөнү үч жолу окуу сизге жетиштүү болот.";

"azkar.e03.title" = "Амсайна ва амсаль-мульку лилляхи";
"azkar.e03.body"  = "Биз кечке жетипиз, бүт мүлк Аллахка таандык; бардык макталуу — Аллахка.";

"azkar.e04.title" = "Сеййид аль-Истигфар";
"azkar.e04.body"  = "Аллахумма анта Рабби… Ким муну ишенч менен кечинде айтып, эртеге чейин каза болсо — Бейиштен болот.";

"azkar.e05.title" = "А'узу би-калимятиллях (×3)";
"azkar.e05.body"  = "А'узу би-калимятилляхит-таммати мин шарри ма халяк — кечинде үч жолу айтуу түнкү чаянды тиштешинен корголоо болот.";

"azkar.e06.title" = "Ля иляха илля Аллах (×10 же ×100)";
"azkar.e06.body"  = "Ля иляха илля Аллаху уахдаху ля шарика лях… Ким күнүнө жүз жолу айтса — он кулду азат кылган сыяктуу болот.";

"azkar.e07.title" = "СубханАллахи ва бихамдих (×100)";
"azkar.e07.body"  = "Күнөөлөр деңиз көбүгүндөй болсо да, кечирилет.";

"azkar.e08.title" = "Бисмиллях менен коргонуу (×3)";
"azkar.e08.body"  = "Бисмилляхил-лязи ля йадурру ма'а исмихи шей'ун фил-арди ва ля фис-сама'и ва хувас-Сами'уль-'Алим.";

"azkar.e09.title" = "Жалкоолуктан, карылыктан, карыздан коргонуу";
"azkar.e09.body"  = "Аллахумма инни а'узу бика миналь-касаль, валь-харами, валь-ма'сами, валь-маграм.";

"azkar.e10.title" = "Йа мукаллибаль-кулюб";
"azkar.e10.body"  = "Оо жүрөктөрдү бурган, жүрөгүмдү өз диниңде бекем кыл.";

"azkar.e11.title" = "Хасби Аллах (×7)";
"azkar.e11.body"  = "Хасбийаллаху ля иляха илля хуа, 'алейхи таваккяльту ва хуа Раббуль-'Аршиль-'Азим — жети жолу.";

"azkar.e12.title" = "Уктаар алдында дуба";
"azkar.e12.body"  = "Бисмика Аллахумма амуту ва ахья. Сенин ысмың менен, оо Аллах, өлөм жана жашайм.";

"azkar.e13.title" = "Аль-Бакаранын акыркы эки аяты";
"azkar.e13.body"  = "Ким Аль-Бакара сүрөөсүнүн акыркы эки аятын түнү окуса — ага жетиштүү болот.";

"azkar.e14.title" = "Истигфар × 100";
"azkar.e14.body"  = "Күнүнө жүз жолу кечирим суроо — Пайгамбардын ﷺ күнүмдүк адати.";

"azkar.e15.title" = "Радиту билляхи Раббан";
"azkar.e15.body"  = "Мен Аллах менен Кожоюнум катары, Ислам менен диним катары, Мухаммад менен ﷺ Пайгамбарым катары ыраазымын — үч жолу.";

"azkar.e16.title" = "Пайгамбарга ﷺ салауат (×10)";
"azkar.e16.body"  = "Кечинде Элчиге ﷺ он салауат — менин шапаатым ага милдеттүү болот.";

"azkar.e17.title" = "Аль-Мульк сүрөөсү";
"azkar.e17.body"  = "Түнү Аль-Мульк сүрөөсүн окуңуз — ал окуучусуна кечирилгенге чейин шапаатчы болот.";

"azkar.e18.title" = "Үй-бүлөнүн аман-эсендиги үчүн дуба";
"azkar.e18.body"  = "Аллахумма ахсин акибатана филь-умури куллиха, ва аджирна мин хизйид-дунья ва 'азабиль-ахира.";

"azkar.e19.title" = "Ислам үстүндө туруктуулук";
"azkar.e19.body"  = "Амсайна 'аля фитратиль-Ислам, ва калиматиль-ихляс, ва 'аля дини набиййина Мухаммад ﷺ…";

"azkar.e20.title" = "Тынч жүрөк";
"azkar.e20.body"  = "Аллахумма инни ас'алюка нафсан бика мутма'иннах, ту'мину билика'ик, ва тарда би када'ик.";

/* Намаздан кийинки зикирлер */
"azkar.p01.title" = "Астагфируллах (×3)";
"azkar.p01.body"  = "Үч жолу кечирим сура, анан: Аллахумма анта ас-Салям ва минка ас-Салям, табаракта йа зуль-джаляли валь-икрам.";

"azkar.p02.title" = "Ля иляха илля Аллах";
"azkar.p02.body"  = "Ля иляха илля Аллаху уахдаху ля шарика лях, ляхуль-мульку ва ляхуль-хамду, ва хуа 'аля кулли шей'ин кадир.";

"azkar.p03.title" = "Аллахумма ля мани'а";
"azkar.p03.body"  = "Аллахумма ля мани'а лима а'тайт, ва ля му'тыя лима мана'т, ва ля йанфа'у заль-джадди минка аль-джадд.";

"azkar.p04.title" = "Тасбих — 33/33/34";
"azkar.p04.body"  = "Субхан-Аллах (×33), Альхамду лиллях (×33), Аллаху Акбар (×33), анан бир жолу: Ля иляха илля Аллах… Күнөөлөрү деңиз көбүгүндөй болсо да кечирилет.";

"azkar.p05.title" = "Аят аль-Курси";
"azkar.p05.body"  = "Ким ар бир парз намаздан кийин Аят аль-Курсини окуса — аны Бейиштен өлүмдөн башка эч нерсе ажыратпайт.";

"azkar.p06.title" = "Үч «Куль» (Багымдат жана Магриб кийин)";
"azkar.p06.body"  = "Аль-Ихлас, аль-Фалак жана ан-Нас сүрөөлөрүн Багымдат менен Магрибтен кийин үч жолудан окуңуз.";

"azkar.p07.title" = "Сени эстөөгө жардам бер";
"azkar.p07.body"  = "Аллахумма а'инни 'аля зикрика, ва шукрика, ва хусни 'ибадатик.";

"azkar.p08.title" = "Төрттөн коргонуу";
"azkar.p08.body"  = "Аллахумма инни а'узу бика мин 'азаби джаханнам, ва мин 'азабиль-кабр, ва мин фитнатиль-махья валь-мамат, ва мин фитнатиль-масих ад-Даджаль.";

"azkar.p09.title" = "Он ирет күбөлүк (Багымдат жана Магриб кийин)";
"azkar.p09.body"  = "Ля иляха илля Аллах… ва хуа 'аля кулли шей'ин кадир — Багымдат менен Магрибтен кийин он жолу.";

"azkar.p10.title" = "Пайдалуу илим үчүн дуба (Багымдаттан кийин)";
"azkar.p10.body"  = "Аллахумма инни ас'алюка 'ильман нафи'ан, ва ризкан таййибан, ва 'амалян мутакаббаля.";

"azkar.p11.title" = "Пайгамбарга ﷺ салауат";
"azkar.p11.body"  = "Ар бир парз намаздан кийин Элчиге ﷺ он салауат жибериңиз.";

"azkar.p12.title" = "Жол көрсөтүү үчүн дуба";
"azkar.p12.body"  = "Аллахумма инни ас'алюкаль-худа ват-тука валь-'афафа валь-гина.";

"azkar.p13.title" = "Алсыздыктан коргонуу";
"azkar.p13.body"  = "Аллахумма инни а'узу бика миналь-'аджзи валь-касаль, валь-джубни валь-бухль, ва дала'ид-дайни ва галябатир-риджаль.";

"azkar.p14.title" = "Жүрөктү бекем кыл";
"azkar.p14.body"  = "Йа мукаллибаль-кулюб, саббит кальби 'аля диник.";

"azkar.p15.title" = "Ата-энени кечирип бер дубасы";
"azkar.p15.body"  = "Рабби-гфир ли ва ли валидаййа ва лиль-му'минина йаума йакумуль-хисаб.";

/* Hadistер — 100 */

"hadith.h01.title" = "Ниет";
"hadith.h01.body"  = "Иштер ниетке жараша. Ар бир адамга ал эмнени ниет кылса, ошол гана болот.";

"hadith.h02.title" = "Сиздердин эң жакшыңыз";
"hadith.h02.body"  = "Силердин ичиңердеги эң жакшысы — эң жакшы адеп-ахлактуу адам.";

"hadith.h03.title" = "Бир тууганга болгон сүйүү";
"hadith.h03.body"  = "Бир тууганыңа өзүңө каалаганды каалабасаң, чындап ыймандуу боло албайсың.";

"hadith.h04.title" = "Жылмаюу — садака";
"hadith.h04.body"  = "Бир тууганыңа жылмайышың — бул садака.";

"hadith.h05.title" = "Беш түркүк";
"hadith.h05.body"  = "Ислам беш түркүккө курулган: Аллахтан башка кудай жок жана Мухаммад Анын элчиси экендигине күбөлүк, намаз, зекет, ажылык жана Рамазан оразасы.";

"hadith.h06.title" = "Аллах сулуу";
"hadith.h06.body"  = "Чындыгында, Аллах сулуу жана сулуулукту сүйөт.";

"hadith.h07.title" = "Намазды өз убагында";
"hadith.h07.body"  = "Аллахтын алдында эң сүйүктүү иш — өз убагында окулган намаз.";

"hadith.h08.title" = "Ырайым";
"hadith.h08.body"  = "Ырайымдууларга Ырайымдуу Жараткан ырайым кылат. Жердегилерге ырайым кылгыла — асмандагы силерге ырайым кылат.";

"hadith.h09.title" = "Жакшы сөз";
"hadith.h09.body"  = "Кимде-ким Аллахка жана Акырет күнүнө ишенсе — жакшы сүйлөсүн же унчукпасын.";

"hadith.h10.title" = "Жылуу жүз";
"hadith.h10.body"  = "Эч бир жакшылыкты кичирейтпегиле — бир тууганыңды жылуу жүз менен тосуп алуу да.";

"hadith.h11.title" = "Эки неемат";
"hadith.h11.body"  = "Көп адам баркын билбей ычкынтчу эки неемат: ден соолук жана бош убакыт.";

"hadith.h12.title" = "Туруктуулук";
"hadith.h12.body"  = "Аллахка эң сүйүктүү иштер — аз болсо да үзгүлтүксүз аткарылгандары.";

"hadith.h13.title" = "Жети адам көлөкөдө";
"hadith.h13.body"  = "Башка көлөкө болбогон Күндө Аллахтын көлөкөсүндө боло турган жети адам — алардын бири Аллахка ибадат менен өскөн жигит.";

"hadith.h14.title" = "Мусулмандын абалы";
"hadith.h14.body"  = "Мусулмандын абалы таң калыштуу: ал үчүн баары жакшы, бул бир гана мусулманга таандык.";

"hadith.h15.title" = "Берешен Кожоюн";
"hadith.h15.body"  = "Кожоюнуңар уяттуу жана берешен: кул Ага колдорун көтөргөндө, аларды бош кайтарганга уялат.";

"hadith.h16.title" = "Тообо";
"hadith.h16.body"  = "Адам баласынын баары күнөөкөр, ал эми күнөөкөрлөрдүн эң жакшысы — тообо кылгандар.";

"hadith.h17.title" = "Илим издөө";
"hadith.h17.body"  = "Ким илим издеп жол жүрсө, Аллах ага Бейишке барчу жолду жеңилдетет.";

"hadith.h18.title" = "Бейиштин кепилдиги";
"hadith.h18.body"  = "Эки ээгинин ортосунда жана эки бутунун ортосунда болгонду мага кепил кылган адамга мен Бейишти кепил болом.";

"hadith.h19.title" = "Төмөнкүгө карагыла";
"hadith.h19.body"  = "Дүйнө иштеринде өзүңөрдөн төмөнкүлөргө, ал эми дин иштеринде жогоркуларга карагыла — Аллахтын неематын унутпашыңар үчүн.";

"hadith.h20.title" = "Коңшу";
"hadith.h20.body"  = "Жабраил мага коңшу жөнүндө ушунча өсүп-танбады — мен аны мураскер кылат го деп ойлодум.";

"hadith.h21.title" = "Уят (хая)";
"hadith.h21.body"  = "Уят (хая) жакшылыктан башка эч нерсе алып келбейт.";

"hadith.h22.title" = "Тилди тыюу";
"hadith.h22.body"  = "Мунун баарынын негизин айтып берейинби? Мына бул — деп, тилин көрсөттү.";

"hadith.h23.title" = "Жакшы жаманды өчүрөт";
"hadith.h23.body"  = "Жаман иштен соң жакшы иш кыл — ал жаманды өчүрөт; жана адамдарга жакшы мүнөз менен мамиле кыл.";

"hadith.h24.title" = "Кыямат күнүндөгү жакындар";
"hadith.h24.body"  = "Мага эң сүйүктүү жана Кыямат күнү мага эң жакын орунда тургандар — адеби эң жакшылары.";

"hadith.h25.title" = "Садака байлыкты азайтпайт";
"hadith.h25.body"  = "Садака мал-мүлктү азайтпайт; кечирген адамды Аллах абийири менен даражалуу кылат.";

"hadith.h26.title" = "Күчтүү дегенибиз";
"hadith.h26.body"  = "Күчтүү — күрөштө жыккан эмес, ачуусу келгенде өзүн тыйган.";

"hadith.h27.title" = "Эки салкын намаз";
"hadith.h27.body"  = "Эки салкын намазды — багымдат менен асрды — окуган адам Бейишке кирет.";

"hadith.h28.title" = "Мусулман";
"hadith.h28.body"  = "Мусулман — тил менен колунан башкалар аман болгон адам.";

"hadith.h29.title" = "Бир тууганыңа жардам бер";
"hadith.h29.body"  = "Ким ыймандуу адамдын бул дүйнөдөгү кайгысын жеңилдетсе, Аллах анын Кыяматтагы кайгысын жеңилдетет.";

"hadith.h30.title" = "Пайгамбарды ﷺ сүйүү";
"hadith.h30.body"  = "Силердин бириңиз да мени атасынан, баласынан жана бардык элден артык сүйгөнгө чейин чын ыймандуу боло албайт.";

"hadith.h31.title" = "Тазалык — ыймандын жарымы";
"hadith.h31.body"  = "Тазалык — ыймандын жарымы, «Альхамдулиллях» таразаны толтурат.";

"hadith.h32.title" = "Дуба — бул ибадат";
"hadith.h32.body"  = "Дуба — ибадаттын өзөгү.";

"hadith.h33.title" = "Шахаданы чын ниет менен суроо";
"hadith.h33.body"  = "Ким Аллахтан шахаданы чын ниет менен сураса — ал төшөгүндө каза болсо да, Аллах ага шейиттин даражасын берет.";

"hadith.h34.title" = "Аллах тообого кубанат";
"hadith.h34.body"  = "Аллах кулунун тообосуна — чөлдө жоготкон төөсүн тапкан адамдан да катуу кубанат.";

"hadith.h35.title" = "Гыйбаттан сактан";
"hadith.h35.body"  = "Гыйбат деген эмне? Бир тууганың жактырбаган нерсени анын жанында эмес жеринде айтуу. Анда бар болсо — жамандаган болосуң; жок болсо — жалаа жапкан болосуң.";

"hadith.h36.title" = "Колду көтөрүү";
"hadith.h36.body"  = "Кожоюнуңар Өзүнө дуба кылып колдорун көтөргөн кулун тамтыктап кайтарбайт.";

"hadith.h37.title" = "Милдет";
"hadith.h37.body"  = "Илим издөө — ар бир мусулманга милдет.";

"hadith.h38.title" = "Иштер аягы менен";
"hadith.h38.body"  = "Иштер аягына жараша бааланат.";

"hadith.h39.title" = "Тилге жеңил эки сөз";
"hadith.h39.body"  = "Тилге жеңил, таразада оор, Ырайымдуу Алладан сүйүктүү эки сөз: «СубханАллахи уа бихамдих, СубханАллахил-Азим».";

"hadith.h40.title" = "Тасбих таразаны толтурат";
"hadith.h40.body"  = "Ким күнүнө жүз жолу «СубханАллахи уа бихамдих» десе, күнөөлөрү деңиз көбүгүндөй болсо да кечирилет.";

"hadith.h41.title" = "Бисмилляхи менен";
"hadith.h41.body"  = "Аллахтын ысмы менен башталбаган ар бир маанилүү иш береке-берметсиз калат.";

"hadith.h42.title" = "Күмөндү калтыр";
"hadith.h42.body"  = "Сени күмөндөндүргөн нерсени таштап, күмөнсүз нерсеге өт.";

"hadith.h43.title" = "Жарды-жалчылар мурда кирет";
"hadith.h43.body"  = "Ыймандуу жарды-жалчылар Бейишке бай адамдардан беш жүз жыл мурда кирет.";

"hadith.h44.title" = "Сабырдуулук — нур";
"hadith.h44.body"  = "Сабырдуулук — нур. Намаз — нур. Куран — сенин пайдаңа же зыяныңа күбө.";

"hadith.h45.title" = "Көрө албастык өрттөйт";
"hadith.h45.body"  = "Көрө албастыктан сак болгула — от отун жеген сыяктуу, ал жакшылыкты жейт.";

"hadith.h46.title" = "Бир тууганыңа жардам";
"hadith.h46.body"  = "Ким мусулмандын дүйнөдөгү бир кыйынчылыгын жеңилдетсе — Аллах анын Кыямат күнүндөгү кыйынчылыгын жеңилдетет.";

"hadith.h47.title" = "Жогорку кол";
"hadith.h47.body"  = "Жогорку кол (берүүчү) — төмөнкү колдон (алуучудан) жакшы.";

"hadith.h48.title" = "Башкаларды кайгыруу";
"hadith.h48.body"  = "Бир тууганына өзүңө каалагандай каалабасаң, чындап ыймандуу болбойсуң.";

"hadith.h49.title" = "Калган үчөө";
"hadith.h49.body"  = "Адам каза болгондо, иштери токтойт — үчөөнөн башкасы: токтобогон садака, пайдасы тийген илим, жана ага дуба кылган салих урпак.";

"hadith.h50.title" = "Рамазандагы эң жакшы садака";
"hadith.h50.body"  = "Эң жакшы садака — Рамазан айында берилгени.";

"hadith.h51.title" = "Кадыр түнү";
"hadith.h51.body"  = "Ким ыйман менен, сооп үмүтү менен Кадыр түнүн кылса — өткөн күнөөлөрү кечирилет.";

"hadith.h52.title" = "Эң пайдалуусу";
"hadith.h52.body"  = "Адамдардын эң жакшысы — адамдарга эң пайдалуусу.";

"hadith.h53.title" = "Аллах жумшактыкты сүйөт";
"hadith.h53.body"  = "Аллах — жумшак, жумшактыкты сүйөт; жумшактык менен катаалдыктан берилбей турган нерсени берет.";

"hadith.h54.title" = "Коңшуну урматта";
"hadith.h54.body"  = "Ким Аллахка жана Акырет күнүнө ишенсе — коңшусун урматтасын.";

"hadith.h55.title" = "Жалганды таштоо";
"hadith.h55.body"  = "Тамаша иретинде да жалган сүйлөбөгөн адамга мен Бейиштин четинде үй кепил болом.";

"hadith.h56.title" = "Жакшы сөз";
"hadith.h56.body"  = "Жакшы сөз — бул садака.";

"hadith.h57.title" = "Жолдон бөгөттү алып сал";
"hadith.h57.body"  = "Ыймандын жетимиш ашуун бутагы бар — эң жогоркусу ыйман күбөлөндүрүү, эң төмөнкүсү жолдон бөгөттү алып салуу.";

"hadith.h58.title" = "Чынчылдык";
"hadith.h58.body"  = "Чынчылдык жакшылыкка, жакшылык Бейишке алып барат.";

"hadith.h59.title" = "Кахфтин акыркы аяттары";
"hadith.h59.body"  = "Ким Кахф сүрөсүнүн акыркы он аятын жатка билсе, Дажжалдан сакталат.";

"hadith.h60.title" = "Жумшактык кооздойт";
"hadith.h60.body"  = "Жумшактык кай жерде болсо — ошол жерди кооздойт; кимден алынса — аны кор кылат.";

"hadith.h61.title" = "Ыймандуулар бир дене";
"hadith.h61.body"  = "Ыймандуулар сүйүү, боорукерлик жана жылуулук жагынан бир дене сыяктуу: бир мүчөсү ооруса, бүт дене ысытма жана уйкусуздук менен жооп берет.";

"hadith.h62.title" = "Чынчылдык жолу";
"hadith.h62.body"  = "Адам чын сүйлөп жүрөт — акыры Аллахтын алдында «чынчыл» деп жазылат.";

"hadith.h63.title" = "Жашырын садака";
"hadith.h63.body"  = "Аллахтын көлөкөсүндөгү жетөөнүн бири — оң колу берген нерсени сол колу билбегендей жашырын садака кылган.";

"hadith.h64.title" = "Ооз ачууну курма менен";
"hadith.h64.body"  = "Силердин бириңер ооз ачканда, курма менен ачсын; таппаса суу менен, анткени ал тазалайт.";

"hadith.h65.title" = "Орозо жана Куран — шапаатчы";
"hadith.h65.body"  = "Орозо менен Куран Кыямат күнү кул үчүн шапаатчы болот.";

"hadith.h66.title" = "Ыйман менен орозо";
"hadith.h66.body"  = "Ким Рамазанды ыйман менен, сооп үмүтү менен орозо кармаса — өткөн күнөөлөрү кечирилет.";

"hadith.h67.title" = "Үч кабыл болгон дуба";
"hadith.h67.body"  = "Үч дуба кайтарылбайт: орозо туткан кишинин, зулум көргөндүн, жана жолоочунун дубасы.";

"hadith.h68.title" = "Бир кесим эт";
"hadith.h68.body"  = "Денеде бир кесим эт бар: ал оңолсо, бардык дене оңолот; бузулса, бардык дене бузулат. Бул — жүрөк.";

"hadith.h69.title" = "Ал жүрөктөргө карайт";
"hadith.h69.body"  = "Аллах силердин көрүнүшүңөргө, малыңарга карабайт — Ал жүрөктөрүңөргө жана иштериңерге карайт.";

"hadith.h70.title" = "Багымдат коргоодо";
"hadith.h70.body"  = "Ким багымдатты окуса — Аллахтын коргоосунда болот.";

"hadith.h71.title" = "Ыймандууга түрмө";
"hadith.h71.body"  = "Бул дүйнө — ыймандуу үчүн түрмө, каапыр үчүн бейиш.";

"hadith.h72.title" = "Күнөө катары жетет";
"hadith.h72.body"  = "Өзүнө кам көрүүчү болгондорду унутканы — адам үчүн күнөө катары жетет.";

"hadith.h73.title" = "Жети кыйратуучу";
"hadith.h73.body"  = "Жети кыйратуучудан сактан: ширк, сыйкыр, акысыз жан кыюу, сүткорлук, жетимдин мүлкүн жеш, согуштан качуу жана ыймандуу аялдарды жалаа менен каралоо.";

"hadith.h74.title" = "Жакшылык — жакшы адеп";
"hadith.h74.body"  = "Жакшылык — жакшы адеп; күнөө — жүрөктө толкундаган, элдин билишин каалабаган нерсе.";

"hadith.h75.title" = "Эң жакшы сырдаштар";
"hadith.h75.body"  = "Аллахтын алдындагы эң жакшы сырдаштар — сырдаштарына эң пайдалуу болгондор; эң жакшы коңшулар — коңшуларына эң пайдалуусу.";

"hadith.h76.title" = "Он эки ракат";
"hadith.h76.body"  = "Ким бир суткада он эки ыктыярдуу ракатты аткарса — ага Бейиште үй курулат.";

"hadith.h77.title" = "Аллах түндө түшөт";
"hadith.h77.body"  = "Түндүн акыркы үчтөн бир бөлүгүндө Кожоюнуңар: «Мага ким кайрылат — жооп берейин; ким сурайт — берейин; ким кечирүү сурайт — кечирейин» — деп айтат.";

"hadith.h78.title" = "Жума күндөгү гусул";
"hadith.h78.body"  = "Жума күнүнүн гусулу — ар бир балагатка жеткен адамга милдет.";

"hadith.h79.title" = "Ар бир муундун садакасы";
"hadith.h79.body"  = "Ар бир эртеңде адамдын ар бир муунуна садака керек — духа намазынын эки ракаты бул баарын алмаштырат.";

"hadith.h80.title" = "Дин — чын ниет";
"hadith.h80.body"  = "Дин — чын ниет: Аллахка, Анын Китебине, Элчисине, мусулман башчыларына жана жалпы элине.";

"hadith.h81.title" = "Элге жакшы мамиле";
"hadith.h81.body"  = "Кайда болсоң да Аллахтан корк; жаман иш кылсаң артынан жакшы иш кыл — ал аны өчүрөт; жана элге жакшы адеп менен мамиле кыл.";

"hadith.h82.title" = "Ачуу — шайтандан";
"hadith.h82.body"  = "Ачуу — шайтандан. Бириңер тургуласа ачуусу келсе — олтурсун; басылса — жакшы, болбосо — жатсын.";

"hadith.h83.title" = "Жарым курма болсо да";
"hadith.h83.body"  = "Оттон өзүңдү сакта — жарым курма менен болсо да; ал да жок болсо — жакшы сөз менен.";

"hadith.h84.title" = "Жүрөк шайкеш болсо окугула";
"hadith.h84.body"  = "Жүрөгүңөр шайкеш болгон убакка чейин Куран окугула; айырмаланса — тургула жана таштагыла.";

"hadith.h85.title" = "Кечирим сура, тообо кыл";
"hadith.h85.body"  = "Аллахка ант, мен күнүнө жетимиш жолудан көп Анын кечиримин сурайм жана Ага тообо кылам.";

"hadith.h86.title" = "Ля иляха илля Аллах × 100";
"hadith.h86.body"  = "Ким күнүнө жүз жолу «Ля иляха илля Аллах...» десе — бул он кул бошотуу сыяктуу, ага жүз жакшылык жазылат.";

"hadith.h87.title" = "Кыяматтагы шапаат";
"hadith.h87.body"  = "Ар бир Пайгамбардын кабыл болчу дубасы болот. Мен өзүмдүкүн Кыямат күнү үммөтүм үчүн шапаат катары сактадым.";

"hadith.h88.title" = "Сыноолор күнөөнү өчүрөт";
"hadith.h88.body"  = "Мусулманга чарчоо, оору, кайгы же зыян — тикенек саныса да — жетпейт, Аллах аны менен анын бир күнөөсүн кечирет.";

"hadith.h89.title" = "Сүннөттө туруктуу";
"hadith.h89.body"  = "Күнүнө он эки суннат ракатын туруктуу окуган адамга Бейиште үй курулат.";

"hadith.h90.title" = "Эң жакшы дуба";
"hadith.h90.body"  = "Эң жакшы дуба: «Кожоюнум, бул дүйнөдө жакшылык, Акыретте жакшылык бер, жана бизди от азабынан сакта».";

"hadith.h91.title" = "Анын адеби — Куран";
"hadith.h91.body"  = "Аллахтын Элчисинин ﷺ адеби — Куран эле.";

"hadith.h92.title" = "Зекет мүлктү тазалайт";
"hadith.h92.body"  = "Зекет — Исламдын көпүрөсү: ал мүлктү тазалайт жана Ырайымдуу Алланы ыраазы кылат.";

"hadith.h93.title" = "Эч кимге каршы айткан эмес";
"hadith.h93.body"  = "Аллахтын Элчиси ﷺ суралган нерсесине «жок» деген эмес.";

"hadith.h94.title" = "Өлүмдү эстегиле";
"hadith.h94.body"  = "Лаззаттарды жок кылуучуну — өлүмдү көп эстегиле.";

"hadith.h95.title" = "Берешен жакын";
"hadith.h95.body"  = "Берешен адам Аллахка, адамдарга, Бейишке жакын, ал эми Оттон алыс.";

"hadith.h96.title" = "Энени урматтоо";
"hadith.h96.body"  = "«Оо, Аллахтын Элчиси, жакшы мамилеме ким татыктуу?» Ал: «Энең». «Андан кийин?» — «Энең». «Андан кийин?» — «Энең». «Андан кийин?» — «Атаң».";

"hadith.h97.title" = "Текеберликтин бурчу";
"hadith.h97.body"  = "Жүрөгүндө кыч тукумдай текеберлиги бар адам Бейишке кирбейт.";

"hadith.h98.title" = "Үй-бүлөгө жакшы";
"hadith.h98.body"  = "Силердин эң жакшыңар — үй-бүлөсүнө эң жакшыңар. Мен үй-бүлөм үчүн силердин эң жакшыңармын.";

"hadith.h99.title" = "Мусулман ыйык";
"hadith.h99.body"  = "Ар бир мусулман башка мусулманга ыйык: каны, мал-мүлкү жана абийири.";

"hadith.h100.title" = "Аллахты сакта";
"hadith.h100.body"  = "Аллахты сакта — Ал сени сактайт. Аллахты сакта — Аны алдыңда табасың. Сураганда — Аллахтан сура; жардам изилегенде — Аллахтан изиле.";
